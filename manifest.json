{
  "manifest_version": 3,
  "name": "CHROME PERFORMANCE",
  "version": "4.1",
  "description": "Tab Manager, Download Manager, Anti-Redirect, Auto-Sleep & Audio Interceptor.",
  "permissions": [
    "tabs",
    "alarms",
    "storage",
    "system.cpu",
    "system.memory",
    "sidePanel",
    "browsingData",
    "idle",
    "tabGroups",
    "webNavigation",
    "downloads",
    "nativeMessaging",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Buka Performance Dashboard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "*://*.elevenlabs.io/*",
        "*://*.suno.com/*",
        "*://*.udio.com/*",
        "*://*.soundcloud.com/*"
      ],
      "js": ["audio_interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
